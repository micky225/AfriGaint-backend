# Local dev
DEBUG=true
SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://afrigaint.com
# Production: ALLOWED_HOSTS=afrigaint-backend.onrender.com,afrigaint.com,www.afrigaint.com,api.afrigaint.com

# Database — required locally (.env) AND on Render (Environment tab; .env is not deployed)
# Render Postgres example:
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local Postgres fallback (only used when DATABASE_URL is unset)
# DB_NAME=afrigaint
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Paystack (GHS deposits)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CURRENCY=GHS
# Browser redirect after hosted checkout — NOT the webhook URL
# PAYSTACK_CALLBACK_URL=https://afrigaint.com/deposit/callback
# Webhook URL (set in Paystack dashboard only):
# https://api.afrigaint.com/api/auth/payments/paystack/webhook/

# Moolre (disabled)
# MOOLRE_USER=
# MOOLRE_PUB_KEY=
# MOOLRE_ACCOUNT_ID=

# Local dev
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production: CORS_ALLOWED_ORIGINS=https://afrigaint.com,https://www.afrigaint.com

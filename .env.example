# Local dev
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://afri-gaint.vercel.app

# Database — use DATABASE_URL (Neon, Render, etc.) or individual DB_* vars for local Postgres
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Local Postgres fallback (only used when DATABASE_URL is unset)
# DB_NAME=afrigaint
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Local dev
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production: CORS_ALLOWED_ORIGINS=https://afri-gaint.vercel.app
